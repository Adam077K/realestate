#!/bin/bash
# ─────────────────────────────────────────────────────────────
#  {{project_name}}-colors.sh — Catppuccin Mocha shared color palette
#  Source this file from any {{project_name}} script:
#    source ~/.tmux/scripts/{{project_name}}-colors.sh
# ─────────────────────────────────────────────────────────────

# ── Catppuccin Mocha base colors ─────────────────────────────
CAT_ROSEWATER="\033[38;2;245;224;220m"
CAT_FLAMINGO="\033[38;2;242;205;205m"
CAT_PINK="\033[38;2;245;194;231m"
CAT_MAUVE="\033[38;2;203;166;247m"
CAT_RED="\033[38;2;243;139;168m"
CAT_MAROON="\033[38;2;235;160;172m"
CAT_PEACH="\033[38;2;250;179;135m"
CAT_YELLOW="\033[38;2;249;226;175m"
CAT_GREEN="\033[38;2;166;227;161m"
CAT_TEAL="\033[38;2;148;226;213m"
CAT_SKY="\033[38;2;137;220;235m"
CAT_SAPPHIRE="\033[38;2;116;199;236m"
CAT_BLUE="\033[38;2;137;180;250m"
CAT_LAVENDER="\033[38;2;180;190;254m"

# ── Catppuccin Mocha surface/text colors ─────────────────────
CAT_TEXT="\033[38;2;205;214;244m"
CAT_SUBTEXT1="\033[38;2;186;194;222m"
CAT_SUBTEXT0="\033[38;2;166;173;200m"
CAT_OVERLAY2="\033[38;2;147;153;178m"
CAT_OVERLAY1="\033[38;2;127;132;156m"
CAT_OVERLAY0="\033[38;2;108;112;134m"
CAT_SURFACE2="\033[38;2;88;91;112m"
CAT_SURFACE1="\033[38;2;69;71;90m"
CAT_SURFACE0="\033[38;2;49;50;68m"
CAT_BASE="\033[38;2;30;30;46m"
CAT_MANTLE="\033[38;2;24;24;37m"
CAT_CRUST="\033[38;2;17;17;27m"

# ── Background variants ───────────────────────────────────────
CAT_BG_BASE="\033[48;2;30;30;46m"
CAT_BG_SURFACE0="\033[48;2;49;50;68m"
CAT_BG_SURFACE1="\033[48;2;69;71;90m"

# ── Reset ─────────────────────────────────────────────────────
RESET="\033[0m"
BOLD="\033[1m"
DIM="\033[2m"

# ── CEO color assignments (Catppuccin accents) ────────────────
# Indexed 0..5, wrap for CEO 7+
CEO_COLORS=("$CAT_MAUVE" "$CAT_GREEN" "$CAT_BLUE" "$CAT_YELLOW" "$CAT_RED" "$CAT_TEAL")
CEO_COLOR_HEX=("#cba6f7" "#a6e3a1" "#89b4fa" "#f9e2af" "#f38ba8" "#94e2d5")
CEO_COLOR_NAMES=("purple" "green" "blue" "yellow" "red" "cyan")

# get_ceo_color N  → ANSI escape for CEO N (1-indexed)
get_ceo_color() {
  local n=$1
  echo -e "${CEO_COLORS[$(( (n - 1) % 6 ))]}"
}

# get_ceo_color_hex N  → hex string for CEO N
get_ceo_color_hex() {
  local n=$1
  echo "${CEO_COLOR_HEX[$(( (n - 1) % 6 ))]}"
}

# get_ceo_color_name N  → color name for CEO N
get_ceo_color_name() {
  local n=$1
  echo "${CEO_COLOR_NAMES[$(( (n - 1) % 6 ))]}"
}
